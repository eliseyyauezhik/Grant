\par \pard\plain \s0\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af6\afs24\alang1081\ltrch\hich\af3\afs24\alang1049\dbch\af8\langfe2052\loch\f3\fs24\lang1049\ql\ltrpar{
\u1056\'d0\u1077\'e5\u1077\'e5\u1089\'f1\u1090\'f2\u1088\'f0 \u1074\'e2\u1089\'f1\u1077\'e5\u1093\'f5 \u1087\'ef\u1086\'ee\u1073\'e1\u1077\'e5\u1076\'e4\u1080\'e8\u1090\'f2\u1077\'e5\u1083\'eb\u1077\'e5\u1081\'e9 \u1080\'e8 \u1087\'ef\u1088\'f0\u1086\'ee\u1077\'e5\u1082\'ea\u1090\'f2\u1086\'ee\u1074\'e2 \u1076\'e4\u1086\'ee\u1089\'f1\u1090\'f2\u1091\'f3\u1087\'ef\u1077\'e5\u1085\'ed \u1074\'e2 \u1088\'f0\u1072\'e0\u1079\'e7\u1076\'e4\u1077\'e5\u1083\'eb\u1077\'e5 \u171\'ab\u1055\'cf\u1088\'f0\u1086\'ee\u1077\'e5\u1082\'ea\u1090\'f2\u1099\'fb\u187\'bb \u1085\'ed\u1072\'e0 \u1087\'ef\u1088\'f0\u1077\'e5\u1079\'e7\u1080\'e8\u1076\'e4\u1077\'e5\u1085\'ed\u1090\'f2\u1089\'f1\u1082\'ea\u1080\'e8\u1077\'e5\u1075\'e3\u1088\'f0\u1072\'e0\u1085\'ed\u1090\'f2\u1099\'fb.\u1088\'f0\u1092\'f4 (\u1092\'f4\u1080\'e8\u1083\'eb\u1100\'fc\u1090\'f2\u1088\'f0\u1099\'fb \u1087\'ef\u1086\'ee \u1082\'ea\u1086\'ee\u1085\'ed\u1082\'ea\u1091\'f3\u1088\'f0\u1089\'f1\u1091\'f3, \u1085\'ed\u1072\'e0\u1087\'ef\u1088\'f0\u1072\'e0\u1074\'e2\u1083\'eb\u1077\'e5\u1085\'ed\u1080\'e8\u1102\'fe, \u1088\'f0\u1077\'e5\u1075\'e3\u1080\'e8\u1086\'ee\u1085\'ed\u1091\'f3). \u1047\'c7\u1072\'e0 2024\u8211\'962025 \u1075\'e3\u1075\'e3. \u1087\'ef\u1086\'ee\u1076\'e4\u1076\'e4\u1077\'e5\u1088\'f0\u1078\'e6\u1072\'e0\u1085\'ed\u1086\'ee \u1073\'e1\u1086\'ee\u1083\'eb\u1077\'e5\u1077\'e5 3000 \u1087\'ef\u1088\'f0\u1086\'ee\u1077\'e5\u1082\'ea\u1090\'f2\u1086\'ee\u1074\'e2 (\u1087\'ef\u1077\'e5\u1088\'f0\u1074\'e2\u1099\'fb\u1081\'e9 \u1082\'ea\u1086\'ee\u1085\'ed\u1082\'ea\u1091\'f3\u1088\'f0\u1089\'f1 2025 \u8212\'97 1497 \u1087\'ef\u1086\'ee\u1073\'e1\u1077\'e5\u1076\'e4\u1080\'e8\u1090\'f2\u1077\'e5\u1083\'eb\u1077\'e5\u1081\'e9, \u1075\'e3\u1088\'f0\u1072\'e0\u1085\'ed\u1090\'f2\u1086\'ee\u1074\'e2\u1099\'fb\u1081\'e9 \u1092\'f4\u1086\'ee\u1085\'ed\u1076\'e4 ~4,7\u8211\'964,9 \u1084\'ec\u1083\'eb\u1088\'f0\u1076\'e4 \u1088\'f0\u1091\'f3\u1073\'e1.). \u1042\'c2\u1099\'fb\u1089\'f1\u1086\'ee\u1082\'ea\u1086\'ee\u1073\'e1\u1072\'e0\u1083\'eb\u1083\'eb\u1100\'fc\u1085\'ed\u1099\'fb\u1077\'e5 (70\u8211\'9680+ \u1073\'e1\u1072\'e0\u1083\'eb\u1083\'eb\u1086\'ee\u1074\'e2) \u1095\'f7\u1072\'e0\u1097\'f9\u1077\'e5 \u1074\'e2\u1089\'f1\u1077\'e5\u1075\'e3\u1086\'ee \u1074\'e2 \u1085\'ed\u1072\'e0\u1087\'ef\u1088\'f0\u1072\'e0\u1074\'e2\u1083\'eb\u1077\'e5\u1085\'ed\u1080\'e8\u1103\'ff\u1093\'f5 \u171\'ab\u1089\'f1\u1086\'ee\u1094\'f6\u1080\'e8\u1072\'e0\u1083\'eb\u1100\'fc\u1085\'ed\u1086\'ee\u1077\'e5 \u1086\'ee\u1073\'e1\u1089\'f1\u1083\'eb\u1091\'f3\u1078\'e6\u1080\'e8\u1074\'e2\u1072\'e0\u1085\'ed\u1080\'e8\u1077\'e5\u187\'bb, \u171\'ab\u1086\'ee\u1093\'f5\u1088\'f0\u1072\'e0\u1085\'ed\u1072\'e0 \u1079\'e7\u1076\'e4\u1086\'ee\u1088\'f0\u1086\'ee\u1074\'e2\u1100\'fc\u1103\'ff\u187\'bb, \u171\'ab\u1087\'ef\u1086\'ee\u1076\'e4\u1076\'e4\u1077\'e5\u1088\'f0\u1078\'e6\u1082\'ea\u1072\'e0 \u1089\'f1\u1077\'e5\u1084\'ec\u1100\'fc\u1080\'e8\u187\'bb, \u171\'ab\u1084\'ec\u1086\'ee\u1083\'eb\u1086\'ee\u1076\'e4\u1105\'b8\u1078\'e6\u1100\'fc\u187\'bb, \u171\'ab\u1082\'ea\u1091\'f3\u1083\'eb\u1100\'fc\u1090\'f2\u1091\'f3\u1088\'f0\u1072\'e0 \u1080\'e8 \u1087\'ef\u1072\'e0\u1090\'f2\u1088\'f0\u1080\'e8\u1086\'ee\u1090\'f2\u1080\'e8\u1095\'f7\u1077\'e5\u1089\'f1\u1082\'ea\u1086\'ee\u1077\'e5 \u1074\'e2\u1086\'ee\u1089\'f1\u1087\'ef\u1080\'e8\u1090\'f2\u1072\'e0\u1085\'ed\u1080\'e8\u1077\'e5\u187\'bb. }
