\par \pard\plain \s0\nowidctlpar\hyphpar0\ltrpar\cf0\kerning1\rtlch\af6\afs24\alang1081\ltrch\hich\af3\afs24\alang1049\dbch\af8\langfe2052\loch\f3\fs24\lang1049\ql\ltrpar{
\u1054\'ce\u1092\'f4\u1080\'e8\u1094\'f6\u1080\'e8\u1072\'e0\u1083\'eb\u1100\'fc\u1085\'ed\u1099\'fb\u1077\'e5 \u1076\'e4\u1086\'ee\u1082\'ea\u1091\'f3\u1084\'ec\u1077\'e5\u1085\'ed\u1090\'f2\u1099\'fb \u1088\'f0\u1072\'e0\u1079\'e7\u1084\'ec\u1077\'e5\u1097\'f9\u1077\'e5\u1085\'ed\u1099\'fb \u1085\'ed\u1072\'e0 \u1089\'f1\u1072\'e0\u1081\'e9\u1090\'f2\u1077\'e5 \u1087\'ef\u1088\'f0\u1077\'e5\u1079\'e7\u1080\'e8\u1076\'e4\u1077\'e5\u1085\'ed\u1090\'f2\u1089\'f1\u1082\'ea\u1080\'e8\u1077\'e5\u1075\'e3\u1088\'f0\u1072\'e0\u1085\'ed\u1090\'f2\u1099\'fb.\u1088\'f0\u1092\'f4 \u1074\'e2 \u1088\'f0\u1072\'e0\u1079\'e7\u1076\'e4\u1077\'e5\u1083\'eb\u1072\'e0\u1093\'f5 \u171\'ab\u1044\'c4\u1086\'ee\u1082\'ea\u1091\'f3\u1084\'ec\u1077\'e5\u1085\'ed\u1090\'f2\u1099\'fb\u187\'bb \u1080\'e8 \u171\'ab\u1052\'cc\u1077\'e5\u1090\'f2\u1086\'ee\u1076\'e4\u1080\'e8\u1095\'f7\u1077\'e5\u1089\'f1\u1082\'ea\u1080\'e8\u1077\'e5 \u1084\'ec\u1072\'e0\u1090\'f2\u1077\'e5\u1088\'f0\u1080\'e8\u1072\'e0\u1083\'eb\u1099\'fb\u187\'bb. \u1050\'ca\u1083\'eb\u1102\'fe\u1095\'f7\u1077\'e5\u1074\'e2\u1086\'ee\u1081\'e9 \u1076\'e4\u1086\'ee\u1082\'ea\u1091\'f3\u1084\'ec\u1077\'e5\u1085\'ed\u1090\'f2 \u8212\'97 **\u1052\'cc\u1077\'e5\u1090\'f2\u1086\'ee\u1076\'e4\u1080\'e8\u1095\'f7\u1077\'e5\u1089\'f1\u1082\'ea\u1080\'e8\u1077\'e5 \u1088\'f0\u1077\'e5\u1082\'ea\u1086\'ee\u1084\'ec\u1077\'e5\u1085\'ed\u1076\'e4\u1072\'e0\u1094\'f6\u1080\'e8\u1080\'e8 \u1087\'ef\u1086\'ee \u1087\'ef\u1086\'ee\u1076\'e4\u1075\'e3\u1086\'ee\u1090\'f2\u1086\'ee\u1074\'e2\u1082\'ea\u1077\'e5 \u1079\'e7\u1072\'e0\u1103\'ff\u1074\'e2\u1086\'ee\u1082\'ea 2026-2.pdf** (\u1080\'e8 \u1072\'e0\u1085\'ed\u1072\'e0\u1083\'eb\u1086\'ee\u1075\'e3\u1080\'e8\u1095\'f7\u1085\'ed\u1099\'fb\u1081\'e9 \u1076\'e4\u1083\'eb\u1103\'ff \u1087\'ef\u1077\'e5\u1088\'f0\u1074\'e2\u1086\'ee\u1075\'e3\u1086\'ee \u1082\'ea\u1086\'ee\u1085\'ed\u1082\'ea\u1091\'f3\u1088\'f0\u1089\'f1\u1072\'e0 2026 \u1075\'e3\u1086\'ee\u1076\'e4\u1072\'e0), \u1087\'ef\u1086\'ee\u1076\'e4\u1075\'e3\u1086\'ee\u1090\'f2\u1086\'ee\u1074\'e2\u1083\'eb\u1077\'e5\u1085\'ed\u1085\'ed\u1099\'fb\u1081\'e9 \u1089\'f1 \u1091\'f3\u1095\'f7\u1105\'b8\u1090\'f2\u1086\'ee\u1084\'ec \u1072\'e0\u1085\'ed\u1072\'e0\u1083\'eb\u1080\'e8\u1079\'e7\u1072\'e0 \u1090\'f2\u1080\'e8\u1087\'ef\u1086\'ee\u1074\'e2\u1099\'fb\u1093\'f5 \u1086\'ee\u1096\'f8\u1080\'e8\u1073\'e1\u1086\'ee\u1082\'ea \u1087\'ef\u1088\'f0\u1077\'e5\u1076\'e4\u1099\'fb\u1076\'e4\u1091\'f3\u1097\'f9\u1080\'e8\u1093\'f5 \u1083\'eb\u1077\'e5\u1090\'f2. \u1047\'c7\u1072\'e0\u1103\'ff\u1074\'e2\u1082\'ea\u1072\'e0 \u1087\'ef\u1086\'ee\u1076\'e4\u1072\'e0\u1105\'b8\u1090\'f2\u1089\'f1\u1103\'ff \u1080\'e8\u1089\'f1\u1082\'ea\u1083\'eb\u1102\'fe\u1095\'f7\u1080\'e8\u1090\'f2\u1077\'e5\u1083\'eb\u1100\'fc\u1085\'ed\u1086\'ee \u1074\'e2 \u1101\'fd\u1083\'eb\u1077\'e5\u1082\'ea\u1090\'f2\u1088\'f0\u1086\'ee\u1085\'ed\u1085\'ed\u1086\'ee\u1081\'e9 \u1092\'f4\u1086\'ee\u1088\'f0\u1084\'ec\u1077\'e5 \u1095\'f7\u1077\'e5\u1088\'f0\u1077\'e5\u1079\'e7 \u1083\'eb\u1080\'e8\u1095\'f7\u1085\'ed\u1099\'fb\u1081\'e9 \u1082\'ea\u1072\'e0\u1073\'e1\u1080\'e8\u1085\'ed\u1077\'e5\u1090\'f2 (\u1101\'fd\u1083\'eb\u1077\'e5\u1082\'ea\u1090\'f2\u1088\'f0\u1086\'ee\u1085\'ed\u1085\'ed\u1072\'e0\u1103\'ff \u1087\'ef\u1086\'ee\u1076\'e4\u1087\'ef\u1080\'e8\u1089\'f1\u1100\'fc \u1086\'ee\u1073\'e1\u1103\'ff\u1079\'e7\u1072\'e0\u1090\'f2\u1077\'e5\u1083\'eb\u1100\'fc\u1085\'ed\u1072\'e0). \u1054\'ce\u1089\'f1\u1085\'ed\u1086\'ee\u1074\'e2\u1085\'ed\u1099\'fb\u1077\'e5 \u1087\'ef\u1086\'ee\u1083\'eb\u1103\'ff: \u1085\'ed\u1072\'e0\u1079\'e7\u1074\'e2\u1072\'e0\u1085\'ed\u1080\'e8\u1077\'e5 \u1087\'ef\u1088\'f0\u1086\'ee\u1077\'e5\u1082\'ea\u1090\'f2\u1072\'e0 (\u8804\'3f300 \u1089\'f1\u1080\'e8\u1084\'ec\u1074\'e2\u1086\'ee\u1083\'eb\u1086\'ee\u1074\'e2), \u1082\'ea\u1088\'f0\u1072\'e0\u1090\'f2\u1082\'ea\u1086\'ee\u1077\'e5 \u1086\'ee\u1087\'ef\u1080\'e8\u1089\'f1\u1072\'e0\u1085\'ed\u1080\'e8\u1077\'e5 (\u8804\'3f3000 \u1089\'f1\u1080\'e8\u1084\'ec\u1074\'e2\u1086\'ee\u1083\'eb\u1086\'ee\u1074\'e2 \u8212\'97 \u1101\'fd\u1090\'f2\u1086\'ee \u1090\'f2\u1077\'e5\u1082\'ea\u1089\'f1\u1090\'f2\u1086\'ee\u1074\'e2\u1072\'e0\u1103\'ff \u1087\'ef\u1088\'f0\u1077\'e5\u1079\'e7\u1077\'e5\u1085\'ed\u1090\'f2\u1072\'e0\u1094\'f6\u1080\'e8\u1103\'ff \u1080\'e8\u1076\'e4\u1077\'e5\u1080\'e8, \u1094\'f6\u1077\'e5\u1083\'eb\u1077\'e5\u1074\'e2\u1086\'ee\u1081\'e9 \u1075\'e3\u1088\'f0\u1091\'f3\u1087\'ef\u1087\'ef\u1099\'fb, \u1089\'f1\u1086\'ee\u1076\'e4\u1077\'e5\u1088\'f0\u1078\'e6\u1072\'e0\u1085\'ed\u1080\'e8\u1103\'ff \u1080\'e8 \u1082\'ea\u1083\'eb\u1102\'fe\u1095\'f7\u1077\'e5\u1074\'e2\u1099\'fb\u1093\'f5 \u1088\'f0\u1077\'e5\u1079\'e7\u1091\'f3\u1083\'eb\u1100\'fc\u1090\'f2\u1072\'e0\u1090\'f2\u1086\'ee\u1074\'e2), \u1086\'ee\u1087\'ef\u1080\'e8\u1089\'f1\u1072\'e0\u1085\'ed\u1080\'e8\u1077\'e5 \u1087\'ef\u1088\'f0\u1086\'ee\u1073\'e1\u1083\'eb\u1077\'e5\u1084\'ec\u1099\'fb (\u8804\'3f5000 \u1089\'f1\u1080\'e8\u1084\'ec\u1074\'e2\u1086\'ee\u1083\'eb\u1086\'ee\u1074\'e2 \u1089\'f1 \u1076\'e4\u1072\'e0\u1085\'ed\u1085\'ed\u1099\'fb\u1084\'ec\u1080\'e8, \u1080\'e8\u1089\'f1\u1089\'f1\u1083\'eb\u1077\'e5\u1076\'e4\u1086\'ee\u1074\'e2\u1072\'e0\u1085\'ed\u1080\'e8\u1103\'ff\u1084\'ec\u1080\'e8 \u1079\'e7\u1072\'e0\u1103\'ff\u1074\'e2\u1080\'e8\u1090\'f2\u1077\'e5\u1083\'eb\u1103\'ff \u1080\'e8 \u1089\'f1\u1089\'f1\u1099\'fb\u1083\'eb\u1082\'ea\u1072\'e0\u1084\'ec\u1080\'e8), \u1094\'f6\u1077\'e5\u1083\'eb\u1100\'fc (\u8804\'3f600 \u1089\'f1\u1080\'e8\u1084\'ec\u1074\'e2\u1086\'ee\u1083\'eb\u1086\'ee\u1074\'e2, SMART-\u1092\'f4\u1086\'ee\u1088\'f0\u1084\'ec\u1091\'f3\u1083\'eb\u1080\'e8\u1088\'f0\u1086\'ee\u1074\'e2\u1082\'ea\u1072\'e0), \u1079\'e7\u1072\'e0\u1076\'e4\u1072\'e0\u1095\'f7\u1080\'e8 (\u8804\'3f300 \u1089\'f1\u1080\'e8\u1084\'ec\u1074\'e2\u1086\'ee\u1083\'eb\u1086\'ee\u1074\'e2 \u1082\'ea\u1072\'e0\u1078\'e6\u1076\'e4\u1072\'e0\u1103\'ff), \u1086\'ee\u1078\'e6\u1080\'e8\u1076\'e4\u1072\'e0\u1077\'e5\u1084\'ec\u1099\'fb\u1077\'e5 \u1088\'f0\u1077\'e5\u1079\'e7\u1091\'f3\u1083\'eb\u1100\'fc\u1090\'f2\u1072\'e0\u1090\'f2\u1099\'fb (\u1082\'ea\u1086\'ee\u1083\'eb\u1080\'e8\u1095\'f7\u1077\'e5\u1089\'f1\u1090\'f2\u1074\'e2\u1077\'e5\u1085\'ed\u1085\'ed\u1099\'fb\u1077\'e5 + \u1082\'ea\u1072\'e0\u1095\'f7\u1077\'e5\u1089\'f1\u1090\'f2\u1074\'e2\u1077\'e5\u1085\'ed\u1085\'ed\u1099\'fb\u1077\'e5 \u1087\'ef\u1086\'ee\u1082\'ea\u1072\'e0\u1079\'e7\u1072\'e0\u1090\'f2\u1077\'e5\u1083\'eb\u1080\'e8), \u1075\'e3\u1077\'e5\u1086\'ee\u1075\'e3\u1088\'f0\u1072\'e0\u1092\'f4\u1080\'e8\u1103\'ff, \u1094\'f6\u1077\'e5\u1083\'eb\u1077\'e5\u1074\'e2\u1099\'fb\u1077\'e5 \u1075\'e3\u1088\'f0\u1091\'f3\u1087\'ef\u1087\'ef\u1099\'fb, \u1082\'ea\u1086\'ee\u1084\'ec\u1072\'e0\u1085\'ed\u1076\'e4\u1072\'e0, \u1073\'e1\u1102\'fe\u1076\'e4\u1078\'e6\u1077\'e5\u1090\'f2 \u1080\'e8 \u1082\'ea\u1072\'e0\u1083\'eb\u1077\'e5\u1085\'ed\u1076\'e4\u1072\'e0\u1088\'f0\u1085\'ed\u1099\'fb\u1081\'e9 \u1087\'ef\u1083\'eb\u1072\'e0\u1085\'ed.}
