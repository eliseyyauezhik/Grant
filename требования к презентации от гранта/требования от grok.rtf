\u1041\'c1\u1102\'fe\u1076\'e4\u1078\'e6\u1077\'e5\u1090\'f2 \u1074\'e2\u1080\'e8\u1079\'e7\u1091\'f3\u1072\'e0\u1083\'eb\u1080\'e8\u1079\'e7\u1080\'e8\u1088\'f0\u1091\'f3\u1077\'e5\u1090\'f2\u1089\'f1\u1103\'ff \u1082\'ea\u1088\'f0\u1091\'f3\u1075\'e3\u1086\'ee\u1074\'e2\u1086\'ee\u1081\'e9 \u1076\'e4\u1080\'e8\u1072\'e0\u1075\'e3\u1088\'f0\u1072\'e0\u1084\'ec\u1084\'ec\u1086\'ee\u1081\'e9 (\u1088\'f0\u1072\'e0\u1089\'f1\u1087\'ef\u1088\'f0\u1077\'e5\u1076\'e4\u1077\'e5\u1083\'eb\u1077\'e5\u1085\'ed\u1080\'e8\u1077\'e5: 30\u8211\'9640% \u8212\'97 \u1086\'ee\u1087\'ef\u1083\'eb\u1072\'e0\u1090\'f2\u1072\'e0 \u1090\'f2\u1088\'f0\u1091\'f3\u1076\'e4\u1072\'e0 \u1080\'e8 \u1074\'e2\u1079\'e7\u1085\'ed\u1086\'ee\u1089\'f1\u1099\'fb, 25\u8211\'9635% \u8212\'97 \u1084\'ec\u1077\'e5\u1088\'f0\u1086\'ee\u1087\'ef\u1088\'f0\u1080\'e8\u1103\'ff\u1090\'f2\u1080\'e8\u1103\'ff, \u1086\'ee\u1089\'f1\u1090\'f2\u1072\'e0\u1083\'eb\u1100\'fc\u1085\'ed\u1086\'ee\u1077\'e5 \u8212\'97 \u1086\'ee\u1073\'e1\u1086\'ee\u1088\'f0\u1091\'f3\u1076\'e4\u1086\'ee\u1074\'e2\u1072\'e0\u1085\'ed\u1080\'e8\u1077\'e5/\u1091\'f3\u1089\'f1\u1083\'eb\u1091\'f3\u1075\'e3\u1080\'e8) + \u1090\'f2\u1072\'e0\u1073\'e1\u1083\'eb\u1080\'e8\u1094\'f6\u1072\'e0 \u1089\'f1 \u1086\'ee\u1073\'e1\u1086\'ee\u1089\'f1\u1085\'ed\u1086\'ee\u1074\'e2\u1072\'e0\u1085\'ed\u1080\'e8\u1077\'e5\u1084\'ec \u1082\'ea\u1072\'e0\u1078\'e6\u1076\'e4\u1086\'ee\u1081\'e9 \u1089\'f1\u1090\'f2\u1072\'e0\u1090\'f2\u1100\'fc\u1080\'e8. \u1050\'ca\u1072\'e0\u1083\'eb\u1077\'e5\u1085\'ed\u1076\'e4\u1072\'e0\u1088\'f0\u1085\'ed\u1099\'fb\u1081\'e9 \u1087\'ef\u1083\'eb\u1072\'e0\u1085\'ed \u8212\'97 Gantt-\u1076\'e4\u1080\'e8\u1072\'e0\u1075\'e3\u1088\'f0\u1072\'e0\u1084\'ec\u1084\'ec\u1072\'e0 \u1080\'e8\u1083\'eb\u1080\'e8 \u1094\'f6\u1074\'e2\u1077\'e5\u1090\'f2\u1085\'ed\u1086\'ee\u1081\'e9 timeline (\u1084\'ec\u1077\'e5\u1089\'f1\u1103\'ff\u1094\'f6\u1099\'fb \u1087\'ef\u1086\'ee \u1075\'e3\u1086\'ee\u1088\'f0\u1080\'e8\u1079\'e7\u1086\'ee\u1085\'ed\u1090\'f2\u1072\'e0\u1083\'eb\u1080\'e8, \u1079\'e7\u1072\'e0\u1076\'e4\u1072\'e0\u1095\'f7\u1080\'e8 \u1087\'ef\u1086\'ee \u1074\'e2\u1077\'e5\u1088\'f0\u1090\'f2\u1080\'e8\u1082\'ea\u1072\'e0\u1083\'eb\u1080\'e8, \u1094\'f6\u1074\'e2\u1077\'e5\u1090\'f2\u1086\'ee\u1074\'e2\u1099\'fb\u1077\'e5 \u1079\'e7\u1086\'ee\u1085\'ed\u1099\'fb \u1087\'ef\u1086\'ee \u1101\'fd\u1090\'f2\u1072\'e0\u1087\'ef\u1072\'e0\u1084\'ec). \u1054\'ce\u1073\'e1\u1103\'ff\u1079\'e7\u1072\'e0\u1090\'f2\u1077\'e5\u1083\'eb\u1100\'fc\u1085\'ed\u1086\'ee: \u1087\'ef\u1088\'f0\u1080\'e8\u1074\'e2\u1103\'ff\u1079\'e7\u1082\'ea\u1072\'e0 \u1084\'ec\u1077\'e5\u1088\'f0\u1086\'ee\u1087\'ef\u1088\'f0\u1080\'e8\u1103\'ff\u1090\'f2\u1080\'e8\u1081\'e9 \u1082\'ea \u1079\'e7\u1072\'e0\u1076\'e4\u1072\'e0\u1095\'f7\u1072\'e0\u1084\'ec \u1080\'e8 \u1088\'f0\u1077\'e5\u1079\'e7\u1091\'f3\u1083\'eb\u1100\'fc\u1090\'f2\u1072\'e0\u1090\'f2\u1072\'e0\u1084\'ec, \u1076\'e4\u1072\'e0\u1090\'f2\u1099\'fb \u1090\'f2\u1086\'ee\u1095\'f7\u1085\'ed\u1099\'fb\u1077\'e5 (\u1044\'c4\u1044\'c4.\u1052\'cc\u1052\'cc.\u1043\'c3\u1043\'c3\u1043\'c3\u1043\'c3), \u1088\'f0\u1077\'e5\u1072\'e0\u1083\'eb\u1080\'e8\u1089\'f1\u1090\'f2\u1080\'e8\u1095\'f7\u1085\'ed\u1099\'fb\u1077\'e5 \u1089\'f1\u1088\'f0\u1086\'ee\u1082\'ea\u1080\'e8. \u1042\'c2\u1099\'fb\u1089\'f1\u1086\'ee\u1082\'ea\u1086\'ee\u1073\'e1\u1072\'e0\u1083\'eb\u1083\'eb\u1100\'fc\u1085\'ed\u1099\'fb\u1077\'e5 \u1087\'ef\u1088\'f0\u1086\'ee\u1077\'e5\u1082\'ea\u1090\'f2\u1099\'fb \u1087\'ef\u1086\'ee\u1082\'ea\u1072\'e0\u1079\'e7\u1099\'fb\u1074\'e2\u1072\'e0\u1102\'fe\u1090\'f2 \u1089\'f1\u1086\'ee\u1092\'f4\u1080\'e8\u1085\'ed\u1072\'e0\u1085\'ed\u1089\'f1\u1080\'e8\u1088\'f0\u1086\'ee\u1074\'e2\u1072\'e0\u1085\'ed\u1080\'e8\u1077\'e5 \u1086\'ee\u1090\'f2\u1076\'e4\u1077\'e5\u1083\'eb\u1100\'fc\u1085\'ed\u1099\'fb\u1084\'ec \u1089\'f1\u1077\'e5\u1075\'e3\u1084\'ec\u1077\'e5\u1085\'ed\u1090\'f2\u1086\'ee\u1084\'ec \u1080\'e8 \u1087\'ef\u1086\'ee\u1076\'e4\u1095\'f7\u1105\'b8\u1088\'f0\u1082\'ea\u1080\'e8\u1074\'e2\u1072\'e0\u1102\'fe\u1090\'f2 \u1101\'fd\u1082\'ea\u1086\'ee\u1085\'ed\u1086\'ee\u1084\'ec\u1080\'e8\u1102\'fe (\u1085\'ed\u1072\'e0\u1087\'ef\u1088\'f0\u1080\'e8\u1084\'ec\u1077\'e5\u1088\'f0, \u1074\'e2\u1086\'ee\u1083\'eb\u1086\'ee\u1085\'ed\u1090\'f2\u1105\'b8\u1088\'f0\u1089\'f1\u1082\'ea\u1080\'e8\u1081\'e9 \u1090\'f2\u1088\'f0\u1091\'f3\u1076\'e4).}
