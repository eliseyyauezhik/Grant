**\u1048\'c8\u1084\'ec\u1087\'ef\u1083\'eb\u1080\'e8\u1082\'ea\u1072\'e0\u1094\'f6\u1080\'e8\u1080\'e8**: \u1093\'f5\u1086\'ee\u1088\'f0\u1086\'ee\u1096\'f8\u1086\'ee \u1089\'f1\u1076\'e4\u1077\'e5\u1083\'eb\u1072\'e0\u1085\'ed\u1085\'ed\u1072\'e0\u1103\'ff \u1087\'ef\u1088\'f0\u1077\'e5\u1079\'e7\u1077\'e5\u1085\'ed\u1090\'f2\u1072\'e0\u1094\'f6\u1080\'e8\u1103\'ff \u1087\'ef\u1086\'ee\u1074\'e2\u1099\'fb\u1096\'f8\u1072\'e0\u1077\'e5\u1090\'f2 \u1096\'f8\u1072\'e0\u1085\'ed\u1089\'f1\u1099\'fb \u1085\'ed\u1072\'e0 10\u8211\'9615 \u1073\'e1\u1072\'e0\u1083\'eb\u1083\'eb\u1086\'ee\u1074\'e2 (\u1074\'e2\u1080\'e8\u1079\'e7\u1091\'f3\u1072\'e0\u1083\'eb\u1080\'e8\u1079\'e7\u1080\'e8\u1088\'f0\u1091\'f3\u1077\'e5\u1090\'f2 \u1083\'eb\u1086\'ee\u1075\'e3\u1080\'e8\u1082\'ea\u1091\'f3 \u1080\'e8 \u1089\'f1\u1085\'ed\u1080\'e8\u1078\'e6\u1072\'e0\u1077\'e5\u1090\'f2 \u1088\'f0\u1080\'e8\u1089\'f1\u1082\'ea \u1090\'f2\u1080\'e8\u1087\'ef\u1086\'ee\u1074\'e2\u1099\'fb\u1093\'f5 \u1086\'ee\u1096\'f8\u1080\'e8\u1073\'e1\u1086\'ee\u1082\'ea). \u1054\'ce\u1085\'ed\u1072\'e0 \u1087\'ef\u1086\'ee\u1084\'ec\u1086\'ee\u1075\'e3\u1072\'e0\u1077\'e5\u1090\'f2 \u1101\'fd\u1082\'ea\u1089\'f1\u1087\'ef\u1077\'e5\u1088\'f0\u1090\'f2\u1072\'e0\u1084\'ec \u1073\'e1\u1099\'fb\u1089\'f1\u1090\'f2\u1088\'f0\u1086\'ee \u1091\'f3\u1074\'e2\u1080\'e8\u1076\'e4\u1077\'e5\u1090\'f2\u1100\'fc \u1089\'f1\u1080\'e8\u1083\'eb\u1100\'fc\u1085\'ed\u1099\'fb\u1077\'e5 \u1089\'f1\u1090\'f2\u1086\'ee\u1088\'f0\u1086\'ee\u1085\'ed\u1099\'fb \u1080\'e8 \u1089\'f1\u1086\'ee\u1086\'ee\u1090\'f2\u1074\'e2\u1077\'e5\u1090\'f2\u1089\'f1\u1090\'f2\u1074\'e2\u1091\'f3\u1077\'e5\u1090\'f2 \u1087\'ef\u1088\'f0\u1080\'e8\u1085\'ed\u1094\'f6\u1080\'e8\u1087\'ef\u1091\'f3 \u171\'ab\u1087\'ef\u1088\'f0\u1086\'ee\u1077\'e5\u1082\'ea\u1090\'f2 \u1076\'e4\u1086\'ee\u1083\'eb\u1078\'e6\u1077\'e5\u1085\'ed \u1073\'e1\u1099\'fb\u1090\'f2\u1100\'fc \u1087\'ef\u1086\'ee\u1085\'ed\u1103\'ff\u1090\'f2\u1077\'e5\u1085\'ed \u1079\'e7\u1072\'e0 3 \u1084\'ec\u1080\'e8\u1085\'ed\u1091\'f3\u1090\'f2\u1099\'fb\u187\'bb. \u1056\'d0\u1077\'e5\u1082\'ea\u1086\'ee\u1084\'ec\u1077\'e5\u1085\'ed\u1076\'e4\u1091\'f3\u1102\'fe \u1089\'f1\u1085\'ed\u1072\'e0\u1095\'f7\u1072\'e0\u1083\'eb\u1072\'e0 \u1079\'e7\u1072\'e0\u1087\'ef\u1086\'ee\u1083\'eb\u1085\'ed\u1080\'e8\u1090\'f2\u1100\'fc \u1079\'e7\u1072\'e0\u1103\'ff\u1074\'e2\u1082\'ea\u1091\'f3 \u1074\'e2 \u1096\'f8\u1072\'e0\u1073\'e1\u1083\'eb\u1086\'ee\u1085\'ed\u1077\'e5, \u1087\'ef\u1086\'ee\u1090\'f2\u1086\'ee\u1084\'ec \u1087\'ef\u1077\'e5\u1088\'f0\u1077\'e5\u1085\'ed\u1077\'e5\u1089\'f1\u1090\'f2\u1080\'e8 \u1082\'ea\u1083\'eb\u1102\'fe\u1095\'f7\u1077\'e5\u1074\'e2\u1099\'fb\u1077\'e5 \u1073\'e1\u1083\'eb\u1086\'ee\u1082\'ea\u1080\'e8 \u1074\'e2 \u1089\'f1\u1083\'eb\u1072\'e0\u1081\'e9\u1076\'e4\u1099\'fb. \u1048\'c8\u1079\'e7\u1091\'f3\u1095\'f7\u1080\'e8\u1090\'f2\u1077\'e5 100 \u1083\'eb\u1091\'f3\u1095\'f7\u1096\'f8\u1080\'e8\u1093\'f5 \u1087\'ef\u1088\'f0\u1086\'ee\u1077\'e5\u1082\'ea\u1090\'f2\u1086\'ee\u1074\'e2 2024 \u1075\'e3\u1086\'ee\u1076\'e4\u1072\'e0 \u1085\'ed\u1072\'e0 \u1090\'f2\u1086\'ee\u1087\'ef.\u1075\'e3\u1088\'f0\u1072\'e0\u1085\'ed\u1090\'f2\u1099\'fb.\u1088\'f0\u1092\'f4 \u8212\'97 \u1090\'f2\u1072\'e0\u1084\'ec \u1083\'eb\u1091\'f3\u1095\'f7\u1096\'f8\u1080\'e8\u1077\'e5 \u1087\'ef\u1088\'f0\u1072\'e0\u1082\'ea\u1090\'f2\u1080\'e8\u1082\'ea\u1080\'e8 \u1074\'e2\u1080\'e8\u1079\'e7\u1091\'f3\u1072\'e0\u1083\'eb\u1080\'e8\u1079\'e7\u1072\'e0\u1094\'f6\u1080\'e8\u1080\'e8 \u1088\'f0\u1077\'e5\u1079\'e7\u1091\'f3\u1083\'eb\u1100\'fc\u1090\'f2\u1072\'e0\u1090\'f2\u1086\'ee\u1074\'e2.}
